<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-inherit="analytic.AnalyticDistributionPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('popupButtons')]" position="before">
            <span class="btn btn-link btn-sm" t-on-click="onApplyExpensePool"
                  title="Apply expense pool ratios based on invoice date">
                Apply General Expense
            </span>
        </xpath>
    </t>

</templates>
