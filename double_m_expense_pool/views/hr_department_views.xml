<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add analytic account to department form -->
    <record id="view_department_form_expense_pool" model="ir.ui.view">
        <field name="name">hr.department.form.expense.pool</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="analytic_account_id"
                    help="Set an analytic account to include this department in the Expense Pool allocation (Employees > Expense Pool)."/>
            </xpath>
        </field>
    </record>

    <!-- Expense Pool list view -->
    <record id="view_department_expense_pool_list" model="ir.ui.view">
        <field name="name">hr.department.expense.pool.list</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="name" string="Department"/>
                <field name="total_employee" string="Headcount" sum="Total"/>
                <field name="headcount_percentage" string="%" widget="percentpie"/>
                <field name="analytic_account_id" string="Analytic Account"/>
            </list>
        </field>
    </record>

    <!-- Expense Pool pie chart view -->
    <record id="view_department_expense_pool_graph" model="ir.ui.view">
        <field name="name">hr.department.expense.pool.graph</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <graph string="Expense Pool Allocation" type="pie">
                <field name="name"/>
                <field name="total_employee" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_expense_pool" model="ir.actions.act_window">
        <field name="name">Expense Pool Allocation</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">list,graph</field>
        <field name="domain">[('analytic_account_id', '!=', False)]</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_department_expense_pool_list')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_department_expense_pool_graph')})]"/>
    </record>
</odoo>
