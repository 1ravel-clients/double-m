<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_expense_pool" model="ir.ui.view">
        <field name="name">account.move.form.inherit.expense_pool</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_post']" position="after">
                <button name="action_apply_expense_pool_distribution"
                        type="object"
                        string="Apply Expense Pool"
                        invisible="move_type != 'in_invoice' or state != 'draft'"
                        class="btn-secondary"
                        groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>
</odoo>
