<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="create_project_wizard_form" model="ir.ui.view">
        <field name="name">create.project.wizard.form</field>
        <field name="model">create.project.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Projects">
                <group>
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="show_all"/>
                    </group>
                </group>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="selected" widget="boolean_toggle"/>
                        <field name="product_name"/>
                        <field name="quantity"/>
                        <field name="invoiced_amount"/>
                        <field name="payment_status"
                            widget="badge"
                            decoration-success="payment_status == 'paid'"
                            decoration-warning="payment_status == 'partial'"
                            decoration-danger="payment_status == 'not_paid'"
                            decoration-muted="payment_status == 'not_invoiced'"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_projects"
                        string="Create Projects"
                        type="object"
                        class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
