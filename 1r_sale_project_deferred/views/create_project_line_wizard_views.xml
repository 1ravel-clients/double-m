<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="create_project_line_wizard_form" model="ir.ui.view">
        <field name="name">create.project.line.wizard.form</field>
        <field name="model">create.project.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Project">
                <div class="alert alert-warning d-flex align-items-center" role="alert"
                     invisible="not payment_warning">
                    <i class="fa fa-exclamation-triangle fa-lg me-2"/>
                    <field name="payment_warning" nolabel="1"/>
                </div>
                <group>
                    <group>
                        <field name="sale_line_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="project_template_id"
                            context="{'active_test': False}"/>
                    </group>
                </group>
                <separator string="Tasks in Template"/>
                <field name="task_tree_html" nolabel="1" readonly="1"/>
                <footer>
                    <button name="action_create_project"
                        string="Create Project"
                        type="object"
                        class="btn-primary"
                        icon="fa-folder-open"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
