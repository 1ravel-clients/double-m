<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_deferred" model="ir.ui.view">
        <field name="name">sale.order.form.deferred.project</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Hide "Delivered" column by default (services company) -->
            <xpath expr="//field[@name='order_line']//field[@name='qty_delivered']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Add "Paid" column after "Invoiced" -->
            <xpath expr="//field[@name='order_line']//field[@name='qty_invoiced']" position="after">
                <field name="amount_paid" string="Paid" optional="show"/>
            </xpath>

            <!-- Add Project link + Create Project button before price -->
            <xpath expr="//field[@name='order_line']//field[@name='price_unit']" position="before">
                <field name="project_id" string="Project" optional="show"
                    groups="project.group_project_user"
                    readonly="1"
                    invisible="not project_id"/>
                <button name="action_create_project_wizard" type="object"
                    title="Create Project"
                    icon="fa-plus-circle"
                    class="btn-link text-primary"
                    invisible="project_id or not product_id"
                    groups="project.group_project_user"/>
            </xpath>
        </field>
    </record>
</odoo>
