<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_deferred" model="ir.ui.view">
        <field name="name">sale.order.form.deferred.project</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Hide "Delivered" column by default (services company) -->
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_delivered']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Add "Paid" columns after "Invoiced" in the list -->
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_invoiced']" position="after">
                <field name="amount_paid" string="Paid" optional="show"
                    decoration-success="payment_percentage &gt;= 100"
                    decoration-warning="payment_percentage &gt; 0 and payment_percentage &lt; 100"
                    decoration-muted="payment_percentage == 0"/>
                <field name="payment_percentage" string="Paid %" optional="show"
                    widget="percentpie"/>
            </xpath>

            <!-- Add Project column right after the product name -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_template_id']" position="after">
                <field name="project_id" column_invisible="1"/>
                <button name="action_open_project" type="object"
                    string="Open Project"
                    class="btn btn-outline-primary btn-sm"
                    invisible="not project_id"
                    groups="project.group_project_user"/>
                <button name="action_create_project_wizard" type="object"
                    string="Create Project"
                    class="btn btn-primary btn-sm"
                    invisible="project_id or not product_id or not id"
                    groups="project.group_project_user"/>
                <field name="project_progress" widget="percentpie"
                    string=" "
                    nolabel="1"
                    class="text-start"
                    invisible="not project_id"
                    groups="project.group_project_user"/>
            </xpath>
        </field>
    </record>
</odoo>
