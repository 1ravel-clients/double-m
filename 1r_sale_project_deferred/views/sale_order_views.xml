<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- "Create Projects" button on the SO form header -->
    <record id="sale_order_view_form_deferred" model="ir.ui.view">
        <field name="name">sale.order.form.deferred.project</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="deferred_project_eligible" invisible="1"/>
                <button name="action_create_project_wizard"
                    string="Create Projects"
                    type="object"
                    class="btn-primary"
                    icon="fa-folder-open"
                    invisible="not deferred_project_eligible or state != 'sale'"
                    groups="project.group_project_user"/>
            </xpath>
        </field>
    </record>

    <!-- Show project_id as a clickable link on each SO line -->
    <record id="sale_order_line_project_link" model="ir.ui.view">
        <field name="name">sale.order.form.line.project.link</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='price_subtotal']" position="before">
                <field name="project_id"
                    string="Project"
                    optional="show"
                    groups="project.group_project_user"/>
            </xpath>
        </field>
    </record>
</odoo>
